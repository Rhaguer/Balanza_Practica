# Plantilla para piloto publicado o ambiente productivo.
# Reemplace los valores "cambie-..." antes de usar.
DJANGO_SECRET_KEY=cambie-esta-clave-por-una-segura-y-larga
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=proyectotitulo.pythonanywhere.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://proyectotitulo.pythonanywhere.com
DJANGO_PUBLIC_BASE_URL=https://proyectotitulo.pythonanywhere.com

DJANGO_DB_NAME=../Datos Proyecto Balanza/db.sqlite3
DJANGO_STATIC_ROOT=../Datos Proyecto Balanza/staticfiles
DJANGO_MEDIA_ROOT=../Datos Proyecto Balanza/media
DJANGO_EXPORT_DIR=../Datos Proyecto Balanza/Excel por Taller
DJANGO_BACKUP_DIR=../Datos Proyecto Balanza/backups
DJANGO_ROLLING_BACKUP_FILENAME=respaldo_base_datos.sqlite3
CLASS_BACKUP_LEAD_SECONDS=30
WORKSHOP_WORKER_INTERVAL_SECONDS=10
DJANGO_LOG_DIR=../Datos Proyecto Balanza/logs

DJANGO_SESSION_COOKIE_AGE=14400
DJANGO_SESSION_EXPIRE_AT_BROWSER_CLOSE=True
DJANGO_HSTS_SECONDS=31536000
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_USE_X_FORWARDED_PROTO=True
# Direcciones del proxy inverso autorizado, por ejemplo 127.0.0.1,::1.
DJANGO_TRUSTED_PROXY_IPS=127.0.0.1,::1
DJANGO_LOG_LEVEL=INFO
DJANGO_HEALTH_CHECK_REQUIRE_LOGIN=True
DJANGO_HEALTH_CHECK_EXPOSE_DETAILS=False

DJANGO_WEIGHT_UPDATE_URL=/api/update_weight/
WEIGHT_API_TOKEN=cambie-este-token-por-uno-largo-y-privado
MAX_WEIGHT_KG=1000
WEIGHT_READING_MAX_AGE_SECONDS=10
WEIGHT_BRIDGE_FIRST=True
WEIGHT_DIRECT_READ_ENABLED=True
BALANZA_SERIAL_PORTS=
BALANZA_SERIAL_BAUDRATES=9600,4800,2400,1200,19200,38400,57600,115200
BALANZA_SERIAL_MODES=8N1,7E1,8E1,7N1,8N2
BALANZA_LINE_CONTROLS=default,rts,dtr_rts,none
BALANZA_PROBE_SECONDS=2
BALANZA_SCAN_TIMEOUT_SECONDS=20
BALANZA_STABLE_SAMPLES=3
BALANZA_STABLE_TOLERANCE_KG=0.020
BALANZA_POLL_COMMANDS=,S\r\n,W\r\n,P\r\n,SI\r\n,Q\r\n,PRINT\r\n

PASSWORD_MAX_AGE_DAYS=120
ENFORCE_INSTITUTIONAL_EMAIL_DOMAIN=True
INSTITUTIONAL_EMAIL_DOMAINS=inacap.cl,inacapmail.cl
USE_INSTITUTIONAL_BRAND=True
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.office365.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_HOST_USER=cambie-cuenta@inacap.cl
DJANGO_EMAIL_HOST_PASSWORD=cambie-credencial-smtp
DJANGO_DEFAULT_FROM_EMAIL=cambie-cuenta@inacap.cl
DJANGO_EMAIL_TIMEOUT=15

DATA_RETENTION_DAYS=1095
AUDIT_LOG_RETENTION_DAYS=365
WEIGHT_READING_RETENTION_DAYS=365
BACKUP_RETENTION_DAYS=180
